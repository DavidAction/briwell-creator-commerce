APP_ENV=production
APP_NAME=Briwell Influencer Intelligence

# Use the Supabase managed PostgreSQL connection string from project settings.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
USE_DATABASE=true
MANAGED_SECRET_PROVIDER=render_environment

# Supabase Auth / OIDC. Prefer Supabase asymmetric JWT signing keys.
AUTH_PROVIDER=oidc
OIDC_ISSUER_URL=https://<project-ref>.supabase.co/auth/v1
OIDC_AUDIENCE=authenticated
OIDC_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
OIDC_ROLE_CLAIM=app_metadata.briwell_role
OIDC_EMAIL_CLAIM=email
OIDC_ALLOWED_ALGORITHMS=ES256,RS256
CORS_ALLOWED_ORIGINS=https://<dashboard-domain>

# AI provider configuration.
GEMINI_API_KEY=<managed-secret-reference>
AI_DRY_RUN=false
ALLOW_LIVE_PROVIDER_CALLS=true
AI_LIVE_REQUIRE_DATABASE=true
AI_LIVE_DAILY_CALL_LIMIT=200
AI_LIVE_DAILY_COST_LIMIT_USD=25.00
AI_LIVE_PER_CREATOR_DAILY_CALL_LIMIT=5

# Operational gates.
BACKUP_RESTORE_TESTED_AT=<iso8601-timestamp>
RATE_LIMIT_ENABLED=true
